# ============================================================
# Pearnly · 环境变量模板（.env.example）
# ============================================================
# 复制本文件为 .env.local 后填值 · .env.local 已被 .gitignore
# 体检 P0-05 (2026-05-21) · 按"必填 / 安全必填 / AI-OCR / OAuth /
# LINE / 邮件 / Xero / 部署 / 本地开发 / MRERP 探测"分区
# 不写任何真实密钥 · 真实值只在生产服务器 systemd 环境变量里
# ============================================================


# ── 1. 必填：无这些项目跑不起来 ───────────────────────────
DATABASE_URL=postgres://user:pass@host:5432/dbname    # PostgreSQL · db.py
JWT_SECRET=                                            # auth.py · JWT 签名 · 至少 32 字节
PORT=7860                                              # uvicorn 端口
LOG_LEVEL=INFO                                         # logging 级别


# ── 2. 安全必填：生产环境必须配 ────────────────────────────
PEARNLY_KMS_KEY=                                       # kms_helper.py · ERP 凭据加密主密钥 · Fernet 32 字节
GITHUB_WEBHOOK_SECRET=                                 # /internal/deploy · GitHub webhook HMAC · 缺失直接 503 (fail-closed)
EMAIL_ENCRYPTION_KEY=                                  # email_ingest.py · 邮箱凭据加密
CORS_ALLOW_ORIGINS=https://pearnly.com                 # P0-04 待落地 · 多个域名用逗号分隔


# ── 3. AI / OCR ────────────────────────────────────────────
GEMINI_API_KEY=                                        # Gemini 主 key · OCR + 销项税 AI 分析
GOOGLE_API_KEY=                                        # Gemini fallback key · 主 key 限流时切
GOOGLE_APPLICATION_CREDENTIALS=                        # Google service account JSON 路径 · Layer 1 Vision OCR
OCR_FLASH_MODEL=gemini-2.5-flash                       # Layer 3 fallback 模型
OCR_FLASHLITE_MODEL=gemini-2.5-flash-lite              # Layer 2 structure 模型
OCR_MAX_PAGES_PER_UPLOAD=5                             # 单次上传 PDF 最大页数
OCR_MAX_FILE_SIZE_MB=20                                # 单文件大小上限
OCR_PIPELINE_CONF_THRESHOLD=0.85                       # OCR 置信度阈值
OCR_PIPELINE_AMOUNT_TOL=0.5                            # 金额校验容差 (฿)
OCR_PIPELINE_THB_PER_USD=35                            # 汇率近似 (USD → THB)
OCR_CONF_AUTO=0.98                                     # 自动归属阈值
OCR_CONF_REVIEW=0.90                                   # 人工复核阈值
# OCR_PDF_GL_LEGACY=false                              # 总账 OCR 走老 pipeline (调试用)
# OCR_PDF_STMT_LEGACY=false                            # 银行流水 OCR 走老 pipeline (调试用)

# ── OCR/LLM 后端收口网关 (services/ai_gateway · 一拨切全产品 Gemini 调用) ──
OCR_LLM_BACKEND=aistudio                               # aistudio(默认·api_key) | vertex(企业·数据驻留) | selfhost(Qwen2.5-VL)
# vertex (google-genai · vertexai=True):
GCP_PROJECT=pearnly                                    # GCP 项目 ID
VERTEX_LOCATION=asia-southeast1                        # 区域 · ⚠ flash-lite 在此区不在目录(切 vertex 见交接坑①)
VERTEX_EMBED_MODEL=gemini-embedding-001                # 与 aistudio 同向量空间 · 勿改(改=知识库索引作废需重建)
AISTUDIO_EMBED_MODEL=gemini-embedding-001              # aistudio embed 模型 · 同上锁向量空间
# selfhost (自托管 Qwen2.5-VL · vLLM OpenAI 兼容):
SELFHOST_OCR_URL=                                      # 如 http://host:8000/v1
SELFHOST_OCR_KEY=                                      # 可选 Bearer
SELFHOST_OCR_MODEL=                                    # 如 Qwen2.5-VL-32B-Instruct
SELFHOST_EMBED_MODEL=                                  # 自托管向量模型


# ── 4. OAuth 一键登录 ─────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=                                # Google Sign-In · client_id
GOOGLE_OAUTH_CLIENT_SECRET=                            # Google Sign-In · client_secret
GOOGLE_OAUTH_REDIRECT_URI=https://pearnly.com/api/auth/google/callback
LINE_LOGIN_CHANNEL_ID=                                 # LINE Login · channel_id
LINE_LOGIN_CHANNEL_SECRET=                             # LINE Login · channel_secret
LINE_LOGIN_REDIRECT_URI=https://pearnly.com/api/auth/line/callback


# ── 5. LINE Bot（用户通知 · @pearnly）────────────────────
LINE_CHANNEL_SECRET=                                   # Messaging API · webhook 签名
LINE_CHANNEL_ACCESS_TOKEN=                             # Messaging API · push token
LINE_BOT_FRIEND_URL=                                   # 用户加好友引导链接
LINE_BOT_BASIC_ID=                                     # @pearnly 之类的 basic ID


# ── 6. 邮件（注册验证码 + 充值确认）──────────────────────
SMTP_HOST=smtp.gmail.com                               # 默认 Gmail
SMTP_PORT=587
SMTP_USER=                                             # 发件账号
SMTP_PASSWORD=                                         # 应用专用密码（非账号密码）
SMTP_FROM=                                             # 默认 = SMTP_USER
SMTP_FROM_NAME=Pearnly
RESEND_API_KEY=                                        # Resend.com 备用通道（auth_signup.py）
RESEND_FROM=Pearnly <noreply@pearnly.com>


# ── 7. Xero ERP 集成 ──────────────────────────────────────
XERO_CLIENT_ID=                                        # Xero OAuth 2.0
XERO_CLIENT_SECRET=


# ── 8. SlipOK · 银行转账截图验证 ─────────────────────────
SLIPOK_API_KEY=                                        # slipok.com · 付款 slip OCR
SLIPOK_BRANCH_ID=


# ── 9. ERP 推送 / 邮件 Ingest 调度 ───────────────────────
ERP_PUSH_TIMEOUT_SEC=30                                # 推送单次超时
ERP_RETRY_TICK_SEC=30                                  # ERP 重试间隔
EMAIL_INGEST_ENABLED=0                                 # 1 = 启动时跑 email worker
EMAIL_INGEST_TICK_SEC=300                              # email worker tick 间隔


# ── 10. 部署 / 运维 ───────────────────────────────────────
PEARNLY_BASE_URL=https://pearnly.com                   # 自身 base URL · OAuth callback / 邮件链接用
PLAYWRIGHT_BROWSERS_PATH=                              # chromium 安装路径 · 一般留空让 playwright 用默认
PDF_STORAGE_DIR=/opt/mrpilot/storage/pdfs              # 上传 PDF 落盘目录
IMAGE_STORAGE_DIR=/opt/mrpilot/storage/images          # 上传图片落盘目录（商品图/logo/印章/签名 · §L4）
ENABLE_RLS=0                                           # 1 = 启用 PostgreSQL Row-Level Security（试点中）
DISABLE_SIGNUP=                                        # 设为 "1" / "true" 关闭注册


# ── 11. 联系方式（前端显示 · overrides 用）───────────────
CONTACT_PHONE=086-889-2228
CONTACT_LINE=@pearnly
CONTACT_LINE_URL=https://line.me/R/ti/p/@pearnly
CONTACT_EMAIL=hello@pearnly.com
CONTACT_ADDRESS=Bangkok, Thailand


# ── 12. 本地开发 / 测试 Demo 账号（可选）─────────────────
DEMO_USERNAME=demo
DEMO_PASSWORD=demo2026
DEMO_PLUS_USERNAME=demo_plus
DEMO_PLUS_PASSWORD=demoplus2026
DEMO_IP_DAILY_LIMIT=20                                 # 同 IP 每日访问上限


# ============================================================
# MR.ERP 批量导入探测脚本凭据 (scripts/probe/probe-mrerp.py 读)
# ============================================================
# 测试账号:Zihao 给的 test01 / TEST2019 公司
MRERP_LOGIN_URL=https://www.mrerp4sme.com/
MRERP_USERNAME=
MRERP_PASSWORD=

# 选公司参数(test01 默认 comidyear=6 seldb=1 = TEST2019 公司)
# 详见 docs/integrations/mrerp-known-facts.md §1 / §3
MRERP_COMIDYEAR=6
MRERP_SELDB=1

# 销项发票模块(SC 赊销)idmenu / selmenu
# 详见 docs/integrations/mrerp-known-facts.md §4
MRERP_IDMENU_SALES_CREDIT=370
MRERP_SELMENU_SALES_CREDIT=118

# Playwright 是否带 UI（探测调试用）· 0 = headless
MRERP_HEADED=1
