{
  "name": "pearnly",
  "private": true,
  "version": "0.0.0",
  "description": "Pearnly · Vite build + Playwright E2E smoke. Not a runtime package.",
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,mjs,css,html,json}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,css,html,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.14"
  }
}
