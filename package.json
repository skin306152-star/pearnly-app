{
  "name": "pearnly",
  "private": true,
  "version": "0.0.0",
  "description": "Pearnly · Vite build + Playwright E2E smoke. Not a runtime package.",
  "scripts": {
    "build": "vite build && node scripts/build-home-css.mjs && node scripts/build-home-js.mjs && node scripts/build-html-minify.mjs",
    "build:watch": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,mjs,ts,css,html,json}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,css,html,json}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "vite": "^6.0.7"
  }
}
