# ============================================================
# MR.ERP 批量导入探测脚本凭据(scripts/probe/probe-mrerp.ts 读)
# ============================================================
# 复制本文件为 .env.local 后填值 · .env.local 已被 .gitignore
# 测试账号:Zihao 给的 test01 / TEST2019 公司

MRERP_LOGIN_URL=https://www.mrerp4sme.com/
MRERP_USERNAME=
MRERP_PASSWORD=

# 选公司参数(test01 默认 comidyear=6 seldb=1 = TEST2019 公司)
# 详见 docs/integrations/mrerp-known-facts.md §1 / §3
MRERP_COMIDYEAR=6
MRERP_SELDB=1

# 销项发票模块(SC 赊销)idmenu / selmenu
# 详见 docs/integrations/mrerp-known-facts.md §4
MRERP_IDMENU_SALES_CREDIT=370
MRERP_SELMENU_SALES_CREDIT=118
